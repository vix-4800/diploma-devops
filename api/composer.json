{
  "name": "diploma/php-api",
  "type": "project",
  "require": {
    "php": ">=8.2",
    "slim/slim": "^4.15.1",
    "slim/psr7": "^1.8.0",
    "vlucas/phpdotenv": "^5.6",
    "monolog/monolog": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --colors=never",
    "lint": "phpcs --standard=PSR12 src"
  },
  "require-dev": {
    "phpunit/phpunit": "^8.5"
  }
}
